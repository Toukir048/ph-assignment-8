BETTER_AUTH_SECRET=replace-with-a-32-character-random-secret
BETTER_AUTH_URL=http://localhost:3000
NEXT_PUBLIC_APP_URL=http://localhost:3000
DATABASE_URL=
# Or use Vercel's default Postgres variable:
# POSTGRES_URL=
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Add this redirect URI in Google Cloud Console:
# http://localhost:3000/api/auth/callback/google
#
# If you open the app with the Network URL shown by Next.js, also add that
# matching callback URL, for example:
# http://192.168.0.100:3000/api/auth/callback/google
#
# Production Vercel values:
# BETTER_AUTH_URL=https://ph-assignment-8-wheat.vercel.app
# NEXT_PUBLIC_APP_URL=https://ph-assignment-8-wheat.vercel.app
# DATABASE_URL=your-vercel-postgres-or-neon-database-url
# POSTGRES_URL=your-vercel-postgres-url
# https://ph-assignment-8-wheat.vercel.app/api/auth/callback/google
